{
	"name": "pr-bot",
	"description": "Cloudflare Worker GitHub App PR review bot MVP.",
	"cloudflare": {
		"label": "PR Bot Worker",
		"products": [
			"Workers"
		],
		"categories": [
			"developer-tools"
		],
		"publish": true
	},
	"dependencies": {
		"hono": "4.11.1"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "0.11.1",
		"@types/node": "24.10.1",
		"@vitest/runner": "3.2.4",
		"@vitest/snapshot": "3.2.4",
		"typescript": "5.9.3",
		"vitest": "3.2.4",
		"wrangler": "4.88.0"
	},
	"private": true,
	"scripts": {
		"build": "wrangler deploy --dry-run",
		"cf-typegen": "wrangler types",
		"deploy": "wrangler deploy",
		"dev": "node scripts/dev.mjs",
		"typecheck": "tsc --noEmit",
		"test": "wrangler deploy --dry-run && npx vitest run --config tests/vitest.config.mts"
	}
}
